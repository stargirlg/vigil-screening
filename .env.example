DATABASE_URL=postgresql://<username>:<password>@localhost:5432/vigil_db
ASYNC_DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/vigil_db

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

FUZZY_NAME_THRESHOLD=85
SCORE_HIGH_THRESHOLD=50

WEIGHT_NAME=25
WEIGHT_DOB=15
WEIGHT_ID=20
WEIGHT_NATIONALITY=10
WEIGHT_OCCUPATION=5
WEIGHT_ADVERSE_MEDIA=10
WEIGHT_PEP=15

NEWS_API_KEY=your_newsapi_key_here
GDELT_ENABLED=false

OFAC_SDN_URL=https://www.treasury.gov/ofac/downloads/sdn.xml
UN_SANCTIONS_URL=https://scsanctions.un.org/resources/xml/en/consolidated.xml

APP_ENV=development
APP_NAME=VIGIL
APP_VERSION=1.0.0
DEBUG=true

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-password